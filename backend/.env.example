# Backend environment template. Copy to backend/.env for local development.
# backend/.env is git-ignored. Never commit real secrets.

# Which settings module to load. Local dev uses development; manage.py
# defaults to this automatically, so you usually do not need to set it.
# DJANGO_SETTINGS_MODULE=config.settings.development

# Security
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS / frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# OpenRouteService (used from Phase 2). Never exposed to the browser.
# Get a free key: sign up at https://openrouteservice.org/dev/#/signup and
# create a token (the free "standard" plan is sufficient for this demo).
ORS_API_KEY=replace-with-openrouteservice-key
# ORS_BASE_URL=https://api.heigit.org
# ORS_REQUEST_TIMEOUT_SECONDS=15
