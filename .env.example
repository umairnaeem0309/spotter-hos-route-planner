# Copy to an ignored .env for local development.
# Never commit real secrets or provider credentials.

# Django/backend
ORS_API_KEY=replace-with-openrouteservice-key
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# React/frontend (public configuration; never put secrets in VITE_* values)
VITE_API_BASE_URL=http://localhost:8000/api